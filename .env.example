# Beispiel-Konfiguration

# API
API_PREFIX=/api/v1

# Database
# Empfehlung: hier per ENV setzen statt hardcoded im Code.
DATABASE_URL=postgresql+psycopg2://deviceapp:SuperSecretPW@localhost:5432/devicedb

# CORS (comma-separated)
# Für Live Server (VSCode) z.B. 5500
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# JWT Auth
JWT_SECRET=change_me
JWT_EXPIRE_HOURS=8
