# ── Connection Manager – Environment Variables ──
# Kopiere diese Datei als .env oder setze die Werte in Portainer.
# Variablen mit "required" MUESSEN gesetzt werden.

# ── PostgreSQL ──
POSTGRES_DB=devicedb
POSTGRES_USER=deviceapp
POSTGRES_PASSWORD=              # required – sicheres Passwort setzen

# ── Backend ──
# DATABASE_URL wird in docker-compose.yml automatisch aus den PG-Variablen gebaut.
# Nur setzen, wenn du eine externe DB nutzen willst:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname

JWT_SECRET=                     # required – langer zufaelliger String
JWT_EXPIRE_HOURS=8

API_PREFIX=/api/v1

# CORS – komma-separiert, oder * fuer alles erlauben
CORS_ORIGINS=*

# ── Ports (Host-seitig) ──
BACKEND_PORT=8082

# DB-Port auf dem Host (fuer direkten Zugriff / Backup-Import)
# Default: nur auf localhost:5433 erreichbar. Leer lassen = nicht exponieren.
DB_PORT=127.0.0.1:5433

# ── pgAdmin (optional – in Portainer Container einfach stoppen wenn nicht gebraucht) ──
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5051
